# Environment
MICROCOLDSPRAY_ENV=development

# Application Settings
MICROCOLDSPRAY_APPLICATION__ENVIRONMENT__MODE=development
MICROCOLDSPRAY_APPLICATION__ENVIRONMENT__LOG_LEVEL=INFO

# Hardware Settings
